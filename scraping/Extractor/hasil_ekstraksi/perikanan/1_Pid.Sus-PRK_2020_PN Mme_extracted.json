  "overview_kasus": {
    "dakwaan": [
      {
        "pasal": "Pasal 84 Ayat (1) Jo. Pasal 8 Ayat (1) Jo. Pasal 55 Ayat (1) Ke-1",
        "peraturan": "Undang-Undang Republik Indonesia Nomor 45 Tahun 2009, Tentang Perubahan Undang-Undang Republik Indonesia Nomor 31 Tahun 2004, Tentang Perikanan dan Kitab Undang-Undang Hukum Pidana"
      }
    ],
    "ringkasan_kejadian": {
      "kronologi_singkat": "Para Terdakwa, yaitu NUJRIL, SAHRIJAL, SATRAT, SARAT, dan SADATRI, secara bersama-sama melakukan penangkapan ikan menggunakan bahan peledak (bom ikan) di Perairan Koja Doi. Terdakwa NUJRIL merakit dan melemparkan bom ikan ke gerombolan ikan, sementara Terdakwa SARAT menghidupkan kompresor sebagai alat bantu pernapasan bagi Terdakwa SAHRIJAL dan Terdakwa SATRAT yang menyelam mengambil ikan mati. Terdakwa SADATRI juga ikut menyelam mengambil ikan tanpa alat bantu pernapasan. Perbuatan ini terungkap setelah anggota Polairud Polda NTT melakukan penyelidikan berdasarkan informasi adanya penangkapan ikan menggunakan bahan peledak di wilayah tersebut, dan kemudian menangkap para Terdakwa di lokasi kejadian.",
      "lokasi_kejadian": "Perairan Koja Doi, Desa Koja Doi, Kecamatan Alok Timur, Kabupaten Sikka, Provinsi NTT",
      "tanggal_kejadian": "07 Januari 2020"
    },
